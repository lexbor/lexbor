#!/usr/bin/make -f

# Uncomment this to turn on verbose mode.
# export DH_VERBOSE=1

DEB_HOST_MULTIARCH ?= $(shell dpkg-architecture -qDEB_HOST_MULTIARCH)

%:
	dh $@ --buildsystem=cmake

override_dh_auto_configure:
	dh_auto_configure -- -DCMAKE_INSTALL_LIBDIR=lib/$(DEB_HOST_MULTIARCH) -DLEXBOR_BUILD_SEPARATELY=ON

override_dh_shlibdeps:
	dh_shlibdeps -l ${PWD}/debian/tmp/usr/lib/$(DEB_HOST_MULTIARCH) -- --ignore-missing-info
