[
    /* Test count: 19 */
    /* Test number: 1 */
    {
        "data": $DATA{ ,12}
            <table><th>
        $DATA,
        "errors": [
            {"line": 1, "col": 7, "id": "expected-doctype-but-got-start-tag"},
            {"line": 1, "col": 11, "id": "unexpected-cell-in-table-body"},
            {"line": 1, "col": 11, "id": "expected-closing-tag-but-got-eof"}
        ],
        "result": $DATA{ ,12}
