            <!doctype html><table>X<style> <tr>x </style> </table>
        $DATA,
        "errors": [
            {"line": 1, "col": 23, "id": "foster-parenting-character"}
        ],
        "result": $DATA{ ,12}
            <!DOCTYPE html>
            <html>
              <head>
              <body>
                "X"
                <table>
                  <style>
                    " <tr>x "
                  " "
        $DATA
    },
    /* Test number: 12 */
    {
        "data": $DATA{ ,12}
            <!doctype html><div><table><a>foo</a> <tr><td>bar</td> </tr></table></div>
        $DATA,
        "errors": [
            {"line": 1, "col": 30, "id": "foster-parenting-start-tag"},
            {"line": 1, "col": 31, "id": "foster-parenting-character"},
            {"line": 1, "col": 32, "id": "foster-parenting-character"},
            {"line": 1, "col": 33, "id": "foster-parenting-character"},
            {"line": 1, "col": 37, "id": "foster-parenting-end-tag"}
        ],
        "result": $DATA{ ,12}
            <!DOCTYPE html>
            <html>
              <head>
              <body>
                <div>
                  <a>
                    "foo"
                  <table>
                    " "
                    <tbody>
                      <tr>
                        <td>
                          "bar"
                        " "
        $DATA
    },
    /* Test number: 13 */
    {
        "data": $DATA{ ,12}
            <frame></frame></frame><frameset><frame><frameset><frame></frameset><noframes></frameset><noframes>
        $DATA,
        "errors": [
            {"line": 1, "col": 7, "id": "expected-doctype-but-got-start-tag"},
            {"line": 1, "col": 7, "id": "unexpected-start-tag-ignored"},
            {"line": 1, "col": 15, "id": "unexpected-end-tag"},
            {"line": 1, "col": 23, "id": "unexpected-end-tag"},
            {"line": 1, "col": 33, "id": "unexpected-start-tag"},
            {"line": 1, "col": 99, "id": "expected-named-closing-tag-but-got-eof"},
            {"line": 1, "col": 99, "id": "eof-in-frameset"}
        ],
        "result": $DATA{ ,12}
            <html>
              <head>
              <frameset>
                <frame>
                <frameset>
                  <frame>
                <noframes>
                  "</frameset><noframes>"
        $DATA
    },
    /* Test number: 14 */
    {
        "data": $DATA{ ,12}
            <!DOCTYPE html><object></html>
        $DATA,
        "errors": [
            {"line": 1, "col": 30, "id": "expected-body-in-scope"},
            {"line": 1, "col": 30, "id": "expected-closing-tag-but-got-eof"}
        ],
        "result": $DATA{ ,12}
            <!DOCTYPE html>
            <html>
              <head>
              <body>
                <object>
        $DATA
    },
]