[
    /* Test count: 14 */
    /* Test number: 1 */
    {
        "data": $DATA{ ,12}
            <!DOCTYPE html><p><b><i><u></p> <p>X
        $DATA,
        "errors": [
            {"line": 1, "col": 31, "id": "unexpected-end-tag"},
            {"line": 1, "col": 36, "id": "expected-closing-tag-but-got-eof"}
        ],
        "result": $DATA{ ,12}
            <!DOCTYPE html>
            <html>
              <head>
              <body>
                <p>
                  <b>
                    <i>
                      <u>
                <b>
                  <i>
                    <u>
                      " "
                      <p>
                        "X"
        $DATA
    },
    /* Test number: 2 */
    {
        "data": $DATA{ ,12}
            <p><b><i><u></p>
            <p>X
        $DATA,
        "errors": [
            {"line": 1, "col": 3, "id": "expected-doctype-but-got-start-tag"},
            {"line": 1, "col": 16, "id": "unexpected-end-tag"},
            {"line": 2, "col": 4, "id": "expected-closing-tag-but-got-eof"}
        ],
        "result": $DATA{ ,12}
            <html>
              <head>
              <body>
                <p>
                  <b>
                    <i>
                      <u>
                <b>
                  <i>
                    <u>
                      "
            "
                      <p>
                        "X"
        $DATA
    },
    /* Test number: 3 */
    {
        "data": $DATA{ ,12}
            <!doctype html></html> <head>
        $DATA,
        "errors": [
            {"line": 1, "col": 29, "id": "expected-eof-but-got-start-tag"},
            {"line": 1, "col": 29, "id": "unexpected-start-tag-ignored"}
        ],
        "result": $DATA{ ,12}
            <!DOCTYPE html>
            <html>
              <head>
              <body>
                " "
        $DATA
    },
    /* Test number: 4 */
    {
        "data": $DATA{ ,12}
            <!doctype html></body><meta>
        $DATA,
        "errors": [
            {"line": 1, "col": 28, "id": "unexpected-start-tag-after-body"}
        ],
        "result": $DATA{ ,12}
            <!DOCTYPE html>
            <html>
              <head>
              <body>
                <meta>
        $DATA
    },
    /* Test number: 5 */
    {
        "data": $DATA{ ,12}
            <html></html><!-- foo -->
        $DATA,
        "errors": [
            {"line": 1, "col": 6, "id": "expected-doctype-but-got-start-tag"}
        ],
        "result": $DATA{ ,12}
            <html>
              <head>
              <body>
            <!--  foo  -->
        $DATA
    },
    /* Test number: 6 */
    {
        "data": $DATA{ ,12}
            <!doctype html></body><title>X</title>
        $DATA,
        "errors": [
            {"line": 1, "col": 29, "id": "unexpected-start-tag-after-body"}
        ],
        "result": $DATA{ ,12}
            <!DOCTYPE html>
            <html>
              <head>
              <body>
                <title>
                  "X"
        $DATA
    },
    /* Test number: 7 */
    {
        "data": $DATA{ ,12}
            <!doctype html><table> X<meta></table>
        $DATA,
        "errors": [
            {"line": 1, "col": 23, "id": "foster-parenting-character"},
            {"line": 1, "col": 24, "id": "foster-parenting-character"},
            {"line": 1, "col": 30, "id": "foster-parenting-start-character"}
        ],
        "result": $DATA{ ,12}
            <!DOCTYPE html>
            <html>
              <head>
              <body>
                " X"
                <meta>
                <table>
        $DATA
    },
    /* Test number: 8 */
    {
        "data": $DATA{ ,12}
            <!doctype html><table> x</table>
        $DATA,
        "errors": [
            {"line": 1, "col": 23, "id": "foster-parenting-character"},
            {"line": 1, "col": 24, "id": "foster-parenting-character"}
        ],
        "result": $DATA{ ,12}
            <!DOCTYPE html>
            <html>
              <head>
              <body>
                " x"
                <table>
        $DATA
    },
