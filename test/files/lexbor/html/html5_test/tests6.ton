[
    /* Test count: 52 */
    /* Test number: 1 */
    {
        "data": $DATA{ ,12}
            <!doctype html></head> <head>
        $DATA,
        "errors": [
            {"line": 1, "col": 29, "id": "unexpected-start-tag"}
        ],
        "result": $DATA{ ,12}
            <!DOCTYPE html>
            <html>
              <head>
              " "
              <body>
        $DATA
    },
    /* Test number: 2 */
    {
        "data": $DATA{ ,12}
            <!doctype html><form><div></form><div>
        $DATA,
        "errors": [
            {"line": 1, "col": 33, "id": "end-tag-too-early-ignored"},
            {"line": 1, "col": 38, "id": "expected-closing-tag-but-got-eof"}
        ],
        "result": $DATA{ ,12}
            <!DOCTYPE html>
            <html>
              <head>
              <body>
                <form>
                  <div>
                    <div>
        $DATA
    },
    /* Test number: 3 */
    {
        "data": $DATA{ ,12}
            <!doctype html><title>&amp;</title>
        $DATA,
        "result": $DATA{ ,12}
            <!DOCTYPE html>
            <html>
              <head>
                <title>
                  "&"
              <body>
        $DATA
    },
