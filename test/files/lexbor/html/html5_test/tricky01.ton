[
    /* Test count: 9 */
    /* Test number: 1 */
    {
        "data": $DATA{ ,12}
            <b><p>Bold </b> Not bold</p>
            Also not bold.
        $DATA,
        "errors": [
            {"line": 1, "col": 3, "id": "expected-doctype-but-got-start-tag"},
            {"line": 1, "col": 15, "id": "adoption-agency-1.3"}
        ],
        "result": $DATA{ ,12}
            <html>
              <head>
              <body>
                <b>
                <p>
                  <b>
                    "Bold "
                  " Not bold"
                "
            Also not bold."
        $DATA
    },
    /* Test number: 2 */
    {
        "data": $DATA{ ,12}
            <html>
            <font color=red><i>Italic and Red<p>Italic and Red </font> Just italic.</p> Italic only.</i> Plain
            <p>I should not be red. <font color=red>Red. <i>Italic and red.</p>
            <p>Italic and red. </i> Red.</font> I should not be red.</p>
            <b>Bold <i>Bold and italic</b> Only Italic </i> Plain
        $DATA,
        "errors": [
            {"line": 1, "col": 6, "id": "expected-doctype-but-got-start-tag"},
            {"line": 2, "col": 58, "id": "adoption-agency-1.3"},
            {"line": 3, "col": 67, "id": "unexpected-end-tag"},
            {"line": 4, "col": 23, "id": "adoption-agency-1.3"},
            {"line": 4, "col": 35, "id": "adoption-agency-1.3"},
            {"line": 5, "col": 30, "id": "adoption-agency-1.3"}
        ],
        "result": $DATA{ ,12}
            <html>
              <head>
              <body>
                <font color="red">
                  <i>
                    "Italic and Red"
                <i>
                  <p>
                    <font color="red">
                      "Italic and Red "
                    " Just italic."
                  " Italic only."
                " Plain
            "
                <p>
                  "I should not be red. "
                  <font color="red">
                    "Red. "
                    <i>
                      "Italic and red."
                <font color="red">
                  <i>
                    "
            "
                <p>
                  <font color="red">
                    <i>
                      "Italic and red. "
                    " Red."
                  " I should not be red."
                "
            "
                <b>
                  "Bold "
                  <i>
                    "Bold and italic"
                <i>
                  " Only Italic "
                " Plain"
        $DATA
    },
    /* Test number: 3 */
    {
        "data": $DATA{ ,12}
            <html><body>
            <p><font size="7">First paragraph.</p>
            <p>Second paragraph.</p></font>
            <b><p><i>Bold and Italic</b> Italic</p>
        $DATA,
        "errors": [
            {"line": 1, "col": 6, "id": "expected-doctype-but-got-start-tag"},
            {"line": 2, "col": 38, "id": "unexpected-end-tag"},
            {"line": 4, "col": 28, "id": "adoption-agency-1.3"},
            {"line": 4, "col": 28, "id": "adoption-agency-1.3"},
            {"line": 4, "col": 39, "id": "unexpected-end-tag"}
        ],
        "result": $DATA{ ,12}
            <html>
              <head>
              <body>
                "
            "
                <p>
                  <font size="7">
                    "First paragraph."
                <font size="7">
                  "
            "
                  <p>
                    "Second paragraph."
                "
            "
                <b>
                <p>
                  <b>
                    <i>
                      "Bold and Italic"
                  <i>
                    " Italic"
        $DATA
    },
    /* Test number: 4 */
    {
        "data": $DATA{ ,12}
            <html>
            <dl>
            <dt><b>Boo
            <dd>Goo?
            </dl>
            </html>
        $DATA,
