[
    /* Test count: 3 */
    /* Test number: 1 */
    {
        "data": $DATA{ ,12}
            <input type="hidden"><frameset>
        $DATA,
        "errors": [
            {"line": 1, "col": 21, "id": "expected-doctype-but-got-start-tag"},
            {"line": 1, "col": 31, "id": "unexpected-start-tag"},
            {"line": 1, "col": 31, "id": "eof-in-frameset"}
        ],
        "result": $DATA{ ,12}
