              <head>
              <frameset>
        $DATA
    },
    /* Test number: 2 */
    {
        "data": $DATA{ ,12}
            <!DOCTYPE html><table><caption><svg>foo</table>bar
        $DATA,
        "errors": [
            {"line": 1, "col": 47, "id": "unexpected-end-tag"},
            {"line": 1, "col": 47, "id": "end-table-tag-in-caption"}
        ],
        "result": $DATA{ ,12}
            <!DOCTYPE html>
            <html>
              <head>
              <body>
                <table>
                  <caption>
                    <svg:svg>
                      "foo"
                "bar"
        $DATA
    },
    /* Test number: 3 */
    {
        "data": $DATA{ ,12}
            <table><tr><td><svg><desc><td></desc><circle>
        $DATA,
        "errors": [
            {"line": 1, "col": 7, "id": "expected-doctype-but-got-start-tag"},
            {"line": 1, "col": 30, "id": "unexpected-cell-end-tag"},
            {"line": 1, "col": 37, "id": "unexpected-end-tag"},
            {"line": 1, "col": 45, "id": "expected-closing-tag-but-got-eof"}
        ],
        "result": $DATA{ ,12}
            <html>
              <head>
              <body>
                <table>
                  <tbody>
                    <tr>
                      <td>
                        <svg:svg>
                          <svg:desc>
                      <td>
                        <circle>
        $DATA
    },
