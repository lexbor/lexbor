[
    /* Test count: 19 */
    /* Test number: 1 */
    {
        "data": $DATA{ ,12}
            <head><noscript><!doctype html><!--foo--></noscript>
        $DATA,
        "errors": [
            {"line": 1, "col": 6, "id": "Unexpected start tag (head). Expected DOCTYPE."},
            {"line": 1, "col": 31, "id": "Unexpected DOCTYPE. Ignored."}
        ],
        "scripting": false,
        "result": $DATA{ ,12}
            <html>
              <head>
                <noscript>
                  <!-- foo -->
              <body>
        $DATA
    },
