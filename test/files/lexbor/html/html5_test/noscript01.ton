            {"line": 1, "col": 34, "id": "html needs to be the first start tag."}
        ],
        "scripting": false,
        "result": $DATA{ ,12}
            <html class="foo">
              <head>
                <noscript>
                  <!-- foo -->
              <body>
        $DATA
    },
