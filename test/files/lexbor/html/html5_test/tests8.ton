[
    /* Test count: 10 */
    /* Test number: 1 */
    {
        "data": $DATA{ ,12}
            <div>
            <div></div>
            </span>x
        $DATA,
        "errors": [
            {"line": 1, "col": 5, "id": "expected-doctype-but-got-start-tag"},
            {"line": 3, "col": 7, "id": "unexpected-end-tag"},
            {"line": 3, "col": 8, "id": "expected-closing-tag-but-got-eof"}
        ],
        "result": $DATA{ ,12}
            <html>
              <head>
              <body>
                <div>
                  "
            "
                  <div>
                  "
            x"
        $DATA
    },
    /* Test number: 2 */
    {
        "data": $DATA{ ,12}
            <div>x<div></div>
            </span>x
        $DATA,
        "errors": [
            {"line": 1, "col": 5, "id": "expected-doctype-but-got-start-tag"},
            {"line": 2, "col": 7, "id": "unexpected-end-tag"},
            {"line": 2, "col": 8, "id": "expected-closing-tag-but-got-eof"}
        ],
        "result": $DATA{ ,12}
            <html>
              <head>
              <body>
                <div>
                  "x"
                  <div>
                  "
            x"
        $DATA
    },
    /* Test number: 3 */
    {
        "data": $DATA{ ,12}
            <div>x<div></div>x</span>x
        $DATA,
        "errors": [
            {"line": 1, "col": 5, "id": "expected-doctype-but-got-start-tag"},
            {"line": 1, "col": 25, "id": "unexpected-end-tag"},
            {"line": 1, "col": 26, "id": "expected-closing-tag-but-got-eof"}
        ],
        "result": $DATA{ ,12}
            <html>
              <head>
              <body>
                <div>
                  "x"
                  <div>
                  "xx"
        $DATA
    },
    /* Test number: 4 */
    {
        "data": $DATA{ ,12}
            <div>x<div></div>y</span>z
        $DATA,
        "errors": [
            {"line": 1, "col": 5, "id": "expected-doctype-but-got-start-tag"},
            {"line": 1, "col": 25, "id": "unexpected-end-tag"},
            {"line": 1, "col": 26, "id": "expected-closing-tag-but-got-eof"}
        ],
        "result": $DATA{ ,12}
            <html>
              <head>
              <body>
                <div>
                  "x"
                  <div>
                  "yz"
        $DATA
    },
    /* Test number: 5 */
    {
        "data": $DATA{ ,12}
            <table><div>x<div></div>x</span>x
        $DATA,
        "errors": [
            {"line": 1, "col": 7, "id": "expected-doctype-but-got-start-tag"},
            {"line": 1, "col": 12, "id": "foster-parenting-start-tag"},
            {"line": 1, "col": 13, "id": "foster-parenting-character"},
            {"line": 1, "col": 18, "id": "foster-parenting-start-tag"},
            {"line": 1, "col": 24, "id": "foster-parenting-end-tag"},
            {"line": 1, "col": 25, "id": "foster-parenting-start-tag"},
            {"line": 1, "col": 32, "id": "foster-parenting-end-tag"},
            {"line": 1, "col": 32, "id": "unexpected-end-tag"},
            {"line": 1, "col": 33, "id": "foster-parenting-character"},
            {"line": 1, "col": 33, "id": "eof-in-table"}
        ],
        "result": $DATA{ ,12}
            <html>
              <head>
              <body>
                <div>
                  "x"
                  <div>
                  "xx"
                <table>
        $DATA
    },
    /* Test number: 6 */
    {
        "data": $DATA{ ,12}
            <table><li><li></table>
        $DATA,
        "errors": [
            {"line": 1, "col": 7, "id": "expected-doctype-but-got-start-tag"},
            {"line": 1, "col": 11, "id": "foster-parenting-start-tag"},
            {"line": 1, "col": 15, "id": "foster-parenting-start-tag"}
        ],
        "result": $DATA{ ,12}
            <html>
              <head>
              <body>
                <li>
                <li>
                <table>
        $DATA
    },
    /* Test number: 7 */
    {
        "data": $DATA{ ,12}
            x<table>x
        $DATA,
        "errors": [
            {"line": 1, "col": 1, "id": "expected-doctype-but-got-chars"},
            {"line": 1, "col": 9, "id": "foster-parenting-character"},
            {"line": 1, "col": 9, "id": "eof-in-table"}
        ],
        "result": $DATA{ ,12}
            <html>
              <head>
              <body>
                "xx"
                <table>
        $DATA
    },
    /* Test number: 8 */
    {
        "data": $DATA{ ,12}
            x<table><table>x
        $DATA,
        "errors": [
            {"line": 1, "col": 1, "id": "expected-doctype-but-got-chars"},
            {"line": 1, "col": 15, "id": "unexpected-start-tag-implies-end-tag"},
            {"line": 1, "col": 16, "id": "foster-parenting-character"},
            {"line": 1, "col": 16, "id": "eof-in-table"}
        ],
        "result": $DATA{ ,12}
            <html>
              <head>
              <body>
                "x"
                <table>
                "x"
                <table>
        $DATA
    },
    /* Test number: 9 */
    {
        "data": $DATA{ ,12}
            <b>a<div></div><div></b>y
        $DATA,
        "errors": [
            {"line": 1, "col": 3, "id": "expected-doctype-but-got-start-tag"},
            {"line": 1, "col": 24, "id": "adoption-agency-1.3"},
            {"line": 1, "col": 25, "id": "expected-closing-tag-but-got-eof"}
        ],
        "result": $DATA{ ,12}
            <html>
              <head>
              <body>
                <b>
                  "a"
                  <div>
                <div>
                  <b>
                  "y"
        $DATA
    },
    /* Test number: 10 */
    {
        "data": $DATA{ ,12}
            <a><div><p></a>
        $DATA,
        "errors": [
            {"line": 1, "col": 3, "id": "expected-doctype-but-got-start-tag"},
            {"line": 1, "col": 15, "id": "adoption-agency-1.3"},
            {"line": 1, "col": 15, "id": "adoption-agency-1.3"},
            {"line": 1, "col": 15, "id": "expected-closing-tag-but-got-eof"}
        ],
        "result": $DATA{ ,12}
            <html>
              <head>
              <body>
                <a>
                <div>
                  <a>
                  <p>
                    <a>
        $DATA
    },
]